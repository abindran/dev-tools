---
import Layout from '../layouts/Layout.astro';
import Base64Tool from '../components/Base64Tool.astro';

export const prerender = true;
---

<Layout title="Base64 Encode & Decode Online - Free Developer Tool">
	<section class="hero">
		<div class="container">
			<h2 class="hero-title">Base64 Encode &amp; Decode</h2>
			<p class="hero-subtitle">
				Fast, secure, and 100% client-side. Your data never leaves your browser.
			</p>
		</div>
	</section>

	<Base64Tool />

	<section class="features">
		<div class="container">
			<div class="features-grid">
				<div class="feature card">
					<div class="feature-icon">⚡</div>
					<h3>Lightning Fast</h3>
					<p>Processing happens entirely in your browser with zero server roundtrips. Instant results.</p>
				</div>
				<div class="feature card">
					<div class="feature-icon">🔒</div>
					<h3>100% Secure</h3>
					<p>Your data never leaves your device. No server storage, no logging, complete privacy.</p>
				</div>
				<div class="feature card">
					<div class="feature-icon">🤖</div>
					<h3>API Access</h3>
					<p>RESTful API at <code>/api/encode</code> and <code>/api/decode</code> for automation and AI agents.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="info">
		<div class="container">
			<div class="info-card card">
				<h3>What is Base64 Encoding?</h3>
				<p>
					Base64 is a binary-to-text encoding scheme that represents binary data in an ASCII string format.
					It's widely used in web development for embedding images in CSS/HTML, encoding email attachments (MIME),
					storing complex data in JSON or XML, and handling authentication tokens like JWT.
				</p>
				<h3>How Does It Work?</h3>
				<p>
					Base64 takes groups of 3 bytes (24 bits) and splits them into 4 groups of 6 bits each.
					Each 6-bit group maps to one of 64 printable ASCII characters (A-Z, a-z, 0-9, +, /),
					with <code>=</code> used as padding. This makes it safe to transmit binary data
					through text-based systems.
				</p>
				<h3>API for Developers &amp; AI</h3>
				<p>
					Integrate our Base64 tool directly into your workflows. Send a POST request
					to <code>/api/encode</code> with a JSON body containing your text, or
					to <code>/api/decode</code> with a JSON body containing the Base64 string.
					Our full <a href="/openapi.json">OpenAPI specification</a> is available for
					LLM orchestrators, LangChain agents, and automation platforms.
				</p>
			</div>
		</div>
	</section>
</Layout>

<style>
	.hero {
		text-align: center;
		padding: 3rem 0 1rem;
	}
	.hero-badge {
		display: inline-block;
		padding: 0.25rem 0.75rem;
		font-size: 0.75rem;
		font-weight: 600;
		color: var(--accent);
		background: var(--accent-glow);
		border-radius: 999px;
		border: 1px solid var(--accent);
		margin-bottom: 1rem;
		letter-spacing: 0.03em;
	}
	.hero-title {
		font-size: clamp(1.75rem, 5vw, 2.5rem);
		font-weight: 800;
		color: var(--text-primary);
		margin-bottom: 0.5rem;
		line-height: 1.2;
	}
	.hero-subtitle {
		color: var(--text-secondary);
		font-size: 1.05rem;
		max-width: 500px;
		margin: 0 auto;
	}

	/* Features */
	.features {
		padding: 3rem 0;
	}
	.features-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}
	.feature {
		padding: 1.5rem;
		text-align: center;
	}
	.feature-icon {
		font-size: 2rem;
		margin-bottom: 0.75rem;
	}
	.feature h3 {
		font-size: 1rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}
	.feature p {
		font-size: 0.875rem;
		color: var(--text-secondary);
		line-height: 1.5;
	}
	.feature code {
		background: var(--bg-tertiary);
		padding: 0.15rem 0.35rem;
		border-radius: 4px;
		font-size: 0.8rem;
		border: 1px solid var(--border);
	}

	/* Info */
	.info {
		padding: 0 0 3rem;
	}
	.info-card {
		padding: 2rem;
	}
	.info-card h3 {
		font-size: 1.1rem;
		font-weight: 700;
		margin-bottom: 0.5rem;
		margin-top: 1.5rem;
		color: var(--text-primary);
	}
	.info-card h3:first-child {
		margin-top: 0;
	}
	.info-card p {
		font-size: 0.9rem;
		color: var(--text-secondary);
		line-height: 1.7;
	}
	.info-card code {
		background: var(--bg-tertiary);
		padding: 0.15rem 0.4rem;
		border-radius: 4px;
		font-size: 0.8rem;
		font-family: 'SF Mono', monospace;
		border: 1px solid var(--border);
	}
	.info-card a {
		color: var(--accent);
		text-decoration: underline;
		text-underline-offset: 2px;
	}
</style>
