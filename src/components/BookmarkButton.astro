---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---
<span
  class="bookmark-hint"
  id="bookmark-hint"
  data-press-mac={t('bookmark.pressMac')}
  data-press-win={t('bookmark.pressWin')}
>
  <span class="bookmark-hint-badge">Tip</span>
  <span class="bookmark-hint-text">{t('bookmark.pressWin')}</span>
</span>

<script>
  const hint = document.getElementById('bookmark-hint');
  const text = hint?.querySelector('.bookmark-hint-text') as HTMLElement | null;
  if (hint && text) {
    const uaData = (navigator as any).userAgentData;
    const platform: string = uaData?.platform ?? navigator.platform ?? '';
    const ua = navigator.userAgent ?? '';
    const isApple = /mac|iphone|ipad|ipod/i.test(platform) || /Macintosh|iPhone|iPad|iPod/.test(ua);
    text.textContent = isApple
      ? (hint.dataset.pressMac ?? 'Press ⌘ + D to bookmark this page')
      : (hint.dataset.pressWin ?? 'Press Ctrl + D to bookmark this page');
  }
</script>
