---
import '../styles/global.css';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import { languages, defaultLang } from '../i18n/ui';
import ThemeToggle from '../components/ThemeToggle.astro';
import LanguagePicker from '../components/LanguagePicker.astro';
import BookmarkButton from '../components/BookmarkButton.astro';

interface Props {
	title?: string;
	description?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { title = t('meta.title'), description = t('meta.description') } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') ?? 'https://base64decode.online';

// Build canonical and hreflang URLs based on current path's locale-stripped form.
const pathParts = Astro.url.pathname.split('/').filter(Boolean);
const restPath = pathParts.length && pathParts[0] in languages ? pathParts.slice(1).join('/') : pathParts.join('/');
const trailing = restPath ? `/${restPath}/` : '/';

function urlFor(loc: string) {
	if (loc === defaultLang) return `${siteUrl}${trailing}`;
	return `${siteUrl}/${loc}${trailing}`;
}

const canonical = urlFor(lang);
const ogLocaleMap: Record<string, string> = {
	en: 'en_US',
	es: 'es_ES',
	fr: 'fr_FR',
	de: 'de_DE',
	it: 'it_IT',
	pt: 'pt_PT',
	nl: 'nl_NL',
	ru: 'ru_RU',
	ja: 'ja_JP',
	ko: 'ko_KR',
	zh: 'zh_CN',
	hi: 'hi_IN',
};
const ogImage = `${siteUrl}/og-image.png`;

const clarityId = import.meta.env.PUBLIC_CLARITY_ID;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<meta name="keywords" content={t('meta.keywords')} />
		<meta name="robots" content="index, follow, max-image-preview:large" />
		<meta name="generator" content={Astro.generator} />
		<meta name="theme-color" content="#0b0b0f" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/favicon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<link rel="canonical" href={canonical} />

		{Object.keys(languages).map((loc) => (
			<link rel="alternate" hreflang={loc} href={urlFor(loc)} />
		))}
		<link rel="alternate" hreflang="x-default" href={urlFor(defaultLang)} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Base64 Tool" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonical} />
		<meta property="og:locale" content={ogLocaleMap[lang] ?? 'en_US'} />
		{Object.keys(languages).filter(l => l !== lang).map(l => (
			<meta property="og:locale:alternate" content={ogLocaleMap[l]} />
		))}
		<meta property="og:image" content={ogImage} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={t('meta.imageAlt')} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />
		<meta name="twitter:image:alt" content={t('meta.imageAlt')} />

		<script is:inline type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@graph": [
				{
					"@type": "WebApplication",
					"name": "Base64 Tool",
					"url": canonical,
					"inLanguage": lang,
					"applicationCategory": "DeveloperApplication",
					"operatingSystem": "All",
					"browserRequirements": "Requires JavaScript. Requires HTML5.",
					"offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
					"description": description,
					"featureList": [
						"Encode text to Base64",
						"Decode Base64 to text",
						"UTF-8 safe",
						"Client-side processing",
						"REST API for developers"
					]
				},
				{
					"@type": "FAQPage",
					"inLanguage": lang,
					"mainEntity": [
						{
							"@type": "Question",
							"name": t('info.what.title'),
							"acceptedAnswer": { "@type": "Answer", "text": t('info.what.body') }
						},
						{
							"@type": "Question",
							"name": t('info.how.title'),
							"acceptedAnswer": { "@type": "Answer", "text": t('info.how.body') }
						},
						{
							"@type": "Question",
							"name": t('info.api.title'),
							"acceptedAnswer": { "@type": "Answer", "text": t('info.api.body') }
						}
					]
				}
			]
		})} />
		{clarityId && (
			<script is:inline define:vars={{ clarityId }}>
				(function(c,l,a,r,i,t,y){
					c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
					t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
					y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
				})(window, document, "clarity", "script", clarityId);
			</script>
		)}
		<script is:inline>
			;(function() {
				var t = localStorage.getItem('theme');
				if (!t) t = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
				document.documentElement.setAttribute('data-theme', t);
				localStorage.setItem('theme', t);
			})();
		</script>
	</head>
	<body>
		<nav class="navbar">
			<div class="navbar-inner">
				<a href={lang === defaultLang ? '/' : `/${lang}/`} class="navbar-logo" aria-label={t('nav.title')}>
					<span class="navbar-logo-icon" aria-hidden="true">⚡</span>
					<span class="navbar-logo-text">{t('nav.title')}</span>
				</a>
				<div class="navbar-actions">
					<BookmarkButton />
					<ThemeToggle />
				</div>
			</div>
			<LanguagePicker />
		</nav>
		<main>
			<slot />
		</main>
		<footer class="site-footer">
			<div class="site-footer-inner">
				<p>{t('footer.text')}</p>
			</div>
		</footer>
	</body>
</html>
